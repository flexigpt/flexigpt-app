{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": [
		"eslint",
		"typescript",
		"unicorn",
		"oxc",
		"react",
		"react-perf",
		"import",
		"node",
		"promise"
	],
	"options": {
		"typeAware": true,
		"typeCheck": true,
		"reportUnusedDisableDirectives": "off"
	},
	"ignorePatterns": [
		"**/node_modules/**",
		"**/dist/**",
		"**/out/**",
		"frontend/.react-router/**",
		"frontend/app/apis/wailsjs/**"
	],
	"rules": {},
	"env": {
		"builtin": true
	}
}
