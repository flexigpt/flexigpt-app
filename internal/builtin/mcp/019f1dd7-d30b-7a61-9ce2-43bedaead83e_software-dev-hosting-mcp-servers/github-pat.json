{
	"schemaVersion": "2026-05-30",
	"bundleID": "019f1dd7-d30b-7a61-9ce2-43bedaead83e",
	"id": "builtin.github.pat",
	"displayName": "GitHub (PAT)",
	"enabled": true,
	"transport": "streamableHttp",
	"isBuiltIn": true,
	"streamableHttp": {
		"url": "https://api.githubcopilot.com/mcp/",
		"authMode": "apiKey",
		"timeoutMS": 30000,
		"headers": {
			"X-MCP-Insiders": "true"
		}
	},
	"trustLevel": "trusted",
	"defaultPolicy": {
		"defaultApprovalRule": "allow",
		"defaultExecutionMode": "auto",
		"requireApprovalForUnknownRisk": true,
		"requireApprovalForWrite": true,
		"requireApprovalForDestructive": true
	},
	"appsPolicy": {
		"enabled": true,
		"allowAppInitiatedToolCalls": true,
		"requireApprovalForOpenLink": true,
		"requireApprovalForContextUpdates": true
	},
	"setup": {
		"note": "Create a GitHub personal access token (fine-grained recommended), then paste it below. FlexiGPT stores it in the OS secret store and sends it as an Authorization: Bearer header.",
		"inputs": [
			{
				"id": "githubPat",
				"kind": "httpHeader",
				"label": "GitHub Personal Access Token",
				"description": "Used as the Authorization bearer token for the GitHub MCP endpoint.",
				"note": "Stored as a secret and never shown again. Leave blank to keep the existing token.",
				"placeholder": "github_pat_... or ghp_...",
				"required": true,
				"httpHeader": {
					"headerName": "Authorization",
					"secret": true,
					"valuePrefix": "Bearer "
				}
			}
		]
	},
	"createdAt": "2026-05-30T00:00:00Z",
	"modifiedAt": "2026-05-30T00:00:00Z"
}
